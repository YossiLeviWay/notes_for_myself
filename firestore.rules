rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Notes
    match /artifacts/notes-for-myself-app/public/data/notes/{noteId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && uidUnchanged();
      allow update: if isDocOwner() && uidUnchanged();
      allow delete: if isDocOwner();
    }

    // Folders
    match /artifacts/notes-for-myself-app/public/data/folders/{folderId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && uidUnchanged();
      allow update: if isDocOwner() && uidUnchanged();
      allow delete: if isDocOwner();
    }

    // Tasks
    match /artifacts/notes-for-myself-app/public/data/tasks/{taskId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && uidUnchanged();
      allow update: if isDocOwner() && uidUnchanged();
      allow delete: if isDocOwner();
    }

    // Task Lists
    match /artifacts/notes-for-myself-app/public/data/taskLists/{listId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && uidUnchanged();
      allow update: if isDocOwner() && uidUnchanged();
      allow delete: if isDocOwner();
    }

    // Global Settings
    match /artifacts/notes-for-myself-app/public/data/settings/global {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated(); // In a real app, this should be more restricted
    }
  }
}
